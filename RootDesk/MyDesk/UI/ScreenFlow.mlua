@ExecSpace("ClientOnly")
method void OnSettingsClick(ButtonClickEvent event)
	-- Open the settings popup ON TOP of the current screen (lobby stays visible behind the dimmer).
	local settings = _EntityService:GetEntityByPath("/ui/SettingsGroup")
	if isvalid(settings) == false then
		return
	end
	-- Sync the sliders to the current volumes before showing.
	local bgm = 1.0
	local sfx = 1.0
	if _SoundManager ~= nil then
		bgm = _SoundManager.bgmVolume
		sfx = _SoundManager.sfxVolume
	end
	self:SetSliderValue("/ui/SettingsGroup/Panel/BgmSlider", bgm)
	self:SetSliderValue("/ui/SettingsGroup/Panel/SfxSlider", sfx)
	self:SetVolumeLabel("/ui/SettingsGroup/Panel/BgmValue", bgm)
	self:SetVolumeLabel("/ui/SettingsGroup/Panel/SfxValue", sfx)
	settings.Enable = true
	log("[ScreenFlow] Settings open (bgm=" .. tostring(bgm) .. " sfx=" .. tostring(sfx) .. ")")
end

@ExecSpace("ClientOnly")
method void OnSettingsCloseClick(ButtonClickEvent event)
	-- Close the settings popup and persist the chosen volumes (one save per close, dirty-checked).
	local settings = _EntityService:GetEntityByPath("/ui/SettingsGroup")
	if isvalid(settings) then
		settings.Enable = false
	end
	if _PlayerSave ~= nil and _SoundManager ~= nil then
		_PlayerSave:SaveVolume(_SoundManager.bgmVolume, _SoundManager.sfxVolume)
	end
	log("[ScreenFlow] Settings close")
end

@ExecSpace("ClientOnly")
method void SetSliderValue(string path, number v)
	-- Set a slider's value without triggering audible surprises (used to sync UI to stored volume).
	local ent = _EntityService:GetEntityByPath(path)
	if isvalid(ent) and ent.SliderComponent ~= nil then
		ent.SliderComponent.Value = v
	end
end

@ExecSpace("ClientOnly")
method void SetVolumeLabel(string path, number v)
	-- Show a volume as an integer percentage (e.g. 0.8 -> "80%").
	local ent = _EntityService:GetEntityByPath(path)
	if isvalid(ent) and ent.TextComponent ~= nil then
		ent.TextComponent.Text = tostring(math.floor(v * 100 + 0.5)) .. "%"
	end
end

@ExecSpace("ClientOnly")
method void OnBgmVolumeChanged(SliderValueChangedEvent event)
	-- BGM slider moved -> apply live and update the % label.
	if _SoundManager ~= nil then
		_SoundManager:SetBgmVolume(event.Value)
	end
	self:SetVolumeLabel("/ui/SettingsGroup/Panel/BgmValue", event.Value)
end

@ExecSpace("ClientOnly")
method void OnSfxVolumeChanged(SliderValueChangedEvent event)
	-- SFX slider moved -> store the new SFX volume and update the % label.
	if _SoundManager ~= nil then
		_SoundManager:SetSfxVolume(event.Value)
	end
	self:SetVolumeLabel("/ui/SettingsGroup/Panel/SfxValue", event.Value)
end

@ExecSpace("ClientOnly")
method void OnBuyClick(string itemId)
	-- Request purchase: the server checks gold/level, deducts, persists, then pushes the result
	-- (toast via BuyResultClient + data resync via ReceiveMyData → RefreshSavedUI).
	local name = itemId
	local sds = _DataService:GetTable("ShopItem")
	if sds ~= nil then
		local row = sds:FindRow("id", itemId)
		if row ~= nil then
			name = row:GetItem("name")
		end
	end
	if _PlayerSave ~= nil then
		_PlayerSave:BuyItem(itemId, name)
	end
	log("[ScreenFlow] buy request " .. tostring(itemId))
end

method table StageList()
	-- The stages offered in the lobby. Must match the Stage_W_S buttons in StageSelectGroup.ui.
	return { "1-1", "1-2", "1-3" }
end

method string PrevStage(string stage)
	-- The stage immediately before `stage` in StageList ("" = first stage or not found).
	local prev = ""
	for _, s in ipairs(self:StageList()) do
		if s == stage then
			return prev
		end
		prev = s
	end
	return ""
end

method string NextStage(string stage)
	-- The stage immediately after `stage` in StageList ("" = last stage or not found).
	local list = self:StageList()
	for i = 1, #list do
		if list[i] == stage then
			if i < #list then
				return list[i + 1]
			end
			return ""
		end
	end
	return ""
end

@ExecSpace("ClientOnly")
method void GoToNextStage(string curStage)
	-- 결과창 '다음 스테이지' 버튼 진입점. 방금 curStage를 클리어했으므로 다음 스테이지는 해금 상태 →
	-- 잠금 체크 없이 바로 진입(맵은 모든 스테이지 공용 "RunStage"). 다음이 없으면 로비로 복귀.
	local nextStage = self:NextStage(curStage)
	if nextStage == "" then
		if _UIToast ~= nil then
			_UIToast:ShowMessage("마지막 스테이지를 클리어했습니다!")
		end
		self:ShowLobby()
		log("[ScreenFlow] no next stage after " .. tostring(curStage) .. " -> lobby")
		return
	end
	self:EnterGameWithLoading(nextStage, "RunStage")
	log("[ScreenFlow] next stage " .. tostring(curStage) .. " -> " .. tostring(nextStage))
end

method string AbbreviateNumber(number value)
	-- Compact currency formatting so long balances stay inside the pill:
	--   950 -> "950", 12300 -> "12.3K", 4500000 -> "4.5M", 1200000000 -> "1.2B", 3.4e12 -> "3.4T".
	-- Under 1000 the raw integer is shown; above that it is scaled by 1000s with one decimal
	-- (a trailing ".0" is dropped, e.g. 2000000 -> "2M" not "2.0M").
	local n = math.floor(value + 0.5)
	if n < 0 then
		return "-" .. self:AbbreviateNumber(-n)
	end
	if n < 1000 then
		return tostring(n)
	end
	local units = { "K", "M", "B", "T" }
	local unitIndex = 1
	local scaled = n / 1000
	while scaled >= 1000 and unitIndex < #units do
		scaled = scaled / 1000
		unitIndex = unitIndex + 1
	end
	-- Round to one decimal; if rounding carries to 1000 (e.g. 999999), promote to the next unit.
	local rounded = math.floor(scaled * 10 + 0.5) / 10
	if rounded >= 1000 and unitIndex < #units then
		rounded = rounded / 1000
		unitIndex = unitIndex + 1
	end
	local text = ""
	if rounded == math.floor(rounded) then
		text = tostring(math.floor(rounded))
	else
		text = string.format("%.1f", rounded)
	end
	return text .. units[unitIndex]
end

method boolean IsStageUnlocked(string stage)
	-- Sequential unlock: the first stage is always open; every later stage opens once the
	-- PREVIOUS stage has been cleared (goal reached, persisted server-side as c_<stage>).
	local prev = self:PrevStage(stage)
	if prev == "" then
		return true
	end
	if _PlayerSave == nil then
		return false
	end
	return _PlayerSave:IsStageCleared(prev)
end

@ExecSpace("ClientOnly")
method void OnStageClick(string stage)
	-- Stage button → enter the run. All stages share the RunStage map; per-stage visuals
	-- (background, tiles, layout) come from the course data (Course<stage>), so there is no
	-- stage→map dataset anymore.
	if self:IsStageUnlocked(stage) == false then
		local prev = self:PrevStage(stage)
		if _UIToast ~= nil then
			_UIToast:ShowMessage(prev .. " 스테이지를 먼저 클리어하세요")
		end
		log("[ScreenFlow] stage " .. tostring(stage) .. " locked (needs clear of " .. tostring(prev) .. ")")
		return
	end
	local mapName = "RunStage"
	self:EnterGameWithLoading(stage, mapName)
	log("[ScreenFlow] stage " .. tostring(stage) .. " -> map " .. tostring(mapName))
end

@ExecSpace("ClientOnly")
method void EnterGameWithLoading(string stage, string mapName)
	-- 로딩 커버로 화면을 덮은 뒤(covered) 스테이지 셋업(러너는 대기), 커버가 걷힐 때(reveal) 러너 시작.
	-- 로딩이 없으면(폴백) 즉시 진입.
	if _LoadingScreen == nil then
		if isvalid(self.stageSelectRoot) then self.stageSelectRoot.Enable = false end
		if isvalid(self.lobbyRoot) then self.lobbyRoot.Enable = false end
		if isvalid(self.titleRoot) then self.titleRoot.Enable = false end
		if _RunGameHud ~= nil then _RunGameHud:GoToStage(stage, mapName) end
		return
	end
	_LoadingScreen:Cover(function()
		if isvalid(self.stageSelectRoot) then self.stageSelectRoot.Enable = false end
		if isvalid(self.lobbyRoot) then self.lobbyRoot.Enable = false end
		if isvalid(self.titleRoot) then self.titleRoot.Enable = false end
		if _RunGameHud ~= nil then _RunGameHud:GoToStageHeld(stage, mapName) end
	end, function()
		if _RunGameHud ~= nil then _RunGameHud:BeginHeldRun() end
	end)
end

@ExecSpace("ClientOnly")
method void OnStageSelectOpenClick(ButtonClickEvent event)
	-- 튜토리얼 3막 진입 시점(combat_start)이면 스테이지 선택 대신 전투 훈련 코스로 바로 들어간다.
	if _TutorialManager ~= nil and _TutorialManager:TryStartCombat() then
		log("[ScreenFlow] start -> tutorial combat act")
		return
	end
	-- Lobby → StageSelect screen (map selection).
	if isvalid(self.lobbyRoot) then
		self.lobbyRoot.Enable = false
	end
	if isvalid(self.stageSelectRoot) then
		self.stageSelectRoot.Enable = true
	end
	self:RefreshSavedUI()
	log("[ScreenFlow] -> StageSelect")
end

@ExecSpace("ClientOnly")
method void OnStageSelectBackClick(ButtonClickEvent event)
	-- StageSelect → Lobby.
	if isvalid(self.stageSelectRoot) then
		self.stageSelectRoot.Enable = false
	end
	if isvalid(self.lobbyRoot) then
		self.lobbyRoot.Enable = true
	end
	log("[ScreenFlow] StageSelect -> Lobby")
end

@ExecSpace("ClientOnly")
method void OnStartClick(ButtonClickEvent event)
	-- Title clicked. 튜토리얼을 아직 끝내지 않은 유저면 곧바로 튜토리얼로 진입, 아니면 로비로 이동한다.
	if _TutorialManager ~= nil and _TutorialManager:RequestTutorialFromTitle() then
		if isvalid(self.titleRoot) then
			self.titleRoot.Enable = false
		end
		log("[ScreenFlow] title -> tutorial")
		return
	end
	-- 로비 진입도 로딩 페이드 전환으로.
	self:ShowLobby()
	log("[ScreenFlow] -> Lobby")
end

@ExecSpace("ClientOnly")
method void ShowTitle()
	-- 타이틀 화면으로 되돌린다(로비/스테이지선택/서브화면/결과창을 모두 숨기고 타이틀만 표시). T키 리셋에서 사용.
	if _ResultUI ~= nil then
		_ResultUI:Hide()
	end
	for _, path in ipairs({ "/ui/EquipGroup", "/ui/BlessGroup", "/ui/ShopGroup", "/ui/SettingsGroup", "/ui/EquipPopupGroup" }) do
		local g = _EntityService:GetEntityByPath(path)
		if isvalid(g) then
			g.Enable = false
		end
	end
	if isvalid(self.lobbyRoot) then
		self.lobbyRoot.Enable = false
	end
	if isvalid(self.stageSelectRoot) then
		self.stageSelectRoot.Enable = false
	end
	if isvalid(self.titleRoot) then
		self.titleRoot.Enable = true
	end
	log("[ScreenFlow] ShowTitle")
end

@ExecSpace("ClientOnly")
method void OnBackClick(ButtonClickEvent event)
	-- Lobby back → return to the title.
	if isvalid(self.lobbyRoot) then
		self.lobbyRoot.Enable = false
	end
	if isvalid(self.titleRoot) then
		self.titleRoot.Enable = true
	end
	log("[ScreenFlow] -> Title")
end

@ExecSpace("ClientOnly")
method void HideAllScreens()
	-- 모든 아웃게임 화면(타이틀/로비/스테이지선택 + 서브 화면)을 숨긴다. 튜토리얼이 첫 접속 시 로비를 거치지 않고
	-- 곧바로 스테이지로 들어갈 때, 인게임 위에 UI 화면이 남지 않도록 사용한다.
	if isvalid(self.titleRoot) then
		self.titleRoot.Enable = false
	end
	if isvalid(self.lobbyRoot) then
		self.lobbyRoot.Enable = false
	end
	if isvalid(self.stageSelectRoot) then
		self.stageSelectRoot.Enable = false
	end
	for _, path in ipairs({ "/ui/EquipGroup", "/ui/BlessGroup", "/ui/ShopGroup", "/ui/SettingsGroup", "/ui/EquipPopupGroup" }) do
		local g = _EntityService:GetEntityByPath(path)
		if isvalid(g) then
			g.Enable = false
		end
	end
	log("[ScreenFlow] HideAllScreens")
end

@ExecSpace("ClientOnly")
method void ShowLobby()
	-- 로비 진입: 로딩 커버로 덮은 뒤(covered) 로비를 표시하고 커버가 걷힌다. 로딩이 없으면 즉시.
	if _LoadingScreen == nil then
		self:DoShowLobby()
		return
	end
	_LoadingScreen:Cover(function()
		self:DoShowLobby()
	end, nil)
end

@ExecSpace("ClientOnly")
method void DoShowLobby()
	-- 실제 로비 표시(로딩 커버 아래에서 수행). Show the lobby screen (called after a run ends from the result panel).
	if isvalid(self.titleRoot) then
		self.titleRoot.Enable = false
	end
	if isvalid(self.stageSelectRoot) then
		self.stageSelectRoot.Enable = false
	end
	if isvalid(self.lobbyRoot) then
		self.lobbyRoot.Enable = true
	end
	self:RefreshSavedUI()
	-- 튜토리얼 2막: 로비로 돌아오면 현재 로비 스텝 안내를 띄우게 알림.
	if _TutorialManager ~= nil then
		_TutorialManager:OnReturnToLobby()
	end
	log("[ScreenFlow] ShowLobby")
end

@ExecSpace("ClientOnly")
method void OnStartGameClick(ButtonClickEvent event)
	-- "게임 시작" → hide all screens and begin the run.
	if isvalid(self.lobbyRoot) then
		self.lobbyRoot.Enable = false
	end
	if isvalid(self.titleRoot) then
		self.titleRoot.Enable = false
	end
	if _RunGameHud ~= nil then
		_RunGameHud:StartGame()
	end
	log("[ScreenFlow] -> Game Start")
end

@ExecSpace("ClientOnly")
method void OnEndPlay()
	-- Release click subscriptions.
	if isvalid(self.startButton) and self.startHandler ~= nil then
		self.startButton:DisconnectEvent(ButtonClickEvent, self.startHandler)
		self.startHandler = nil
	end
	if isvalid(self.backButton) and self.backHandler ~= nil then
		self.backButton:DisconnectEvent(ButtonClickEvent, self.backHandler)
		self.backHandler = nil
	end
	if isvalid(self.startGameButton) and self.startGameHandler ~= nil then
		self.startGameButton:DisconnectEvent(ButtonClickEvent, self.startGameHandler)
		self.startGameHandler = nil
	end
	if self.stageHandlers ~= nil then
		for _, rec in ipairs(self.stageHandlers) do
			if isvalid(rec.ent) and rec.hd ~= nil then
				rec.ent:DisconnectEvent(ButtonClickEvent, rec.hd)
			end
		end
		self.stageHandlers = nil
	end
	local startBtn = _EntityService:GetEntityByPath("/ui/LobbyGroup/StartBtn")
	if isvalid(startBtn) and self.stageSelectOpenHandler ~= nil then
		startBtn:DisconnectEvent(ButtonClickEvent, self.stageSelectOpenHandler)
		self.stageSelectOpenHandler = nil
	end
	local stageBack = _EntityService:GetEntityByPath("/ui/StageSelectGroup/BackBtn")
	if isvalid(stageBack) and self.stageSelectBackHandler ~= nil then
		stageBack:DisconnectEvent(ButtonClickEvent, self.stageSelectBackHandler)
		self.stageSelectBackHandler = nil
	end
	local equipBtn = _EntityService:GetEntityByPath("/ui/LobbyGroup/EquipBtn")
	if isvalid(equipBtn) and self.equipHandler ~= nil then
		equipBtn:DisconnectEvent(ButtonClickEvent, self.equipHandler)
		self.equipHandler = nil
	end
	local equipBack = _EntityService:GetEntityByPath("/ui/EquipGroup/BackBtn")
	if isvalid(equipBack) and self.equipBackHandler ~= nil then
		equipBack:DisconnectEvent(ButtonClickEvent, self.equipBackHandler)
		self.equipBackHandler = nil
	end
	local blessBack = _EntityService:GetEntityByPath("/ui/BlessGroup/BackBtn")
	if isvalid(blessBack) and self.blessBackHandler ~= nil then
		blessBack:DisconnectEvent(ButtonClickEvent, self.blessBackHandler)
		self.blessBackHandler = nil
	end
	local blessBtn = _EntityService:GetEntityByPath("/ui/LobbyGroup/BlessBtn")
	if isvalid(blessBtn) and self.blessHandler ~= nil then
		blessBtn:DisconnectEvent(ButtonClickEvent, self.blessHandler)
		self.blessHandler = nil
	end
	local blessUp = _EntityService:GetEntityByPath("/ui/BlessGroup/EffectList/LevelUpBtn")
	if isvalid(blessUp) and self.blessUpHandler ~= nil then
		blessUp:DisconnectEvent(ButtonClickEvent, self.blessUpHandler)
		self.blessUpHandler = nil
	end
	if self.blessRowHandlers ~= nil then
		for _, rec in ipairs(self.blessRowHandlers) do
			if isvalid(rec.ent) and rec.hd ~= nil then
				rec.ent:DisconnectEvent(ButtonClickEvent, rec.hd)
			end
		end
		self.blessRowHandlers = nil
	end
	local blessReset = _EntityService:GetEntityByPath("/ui/BlessGroup/EffectList/ResetBtn")
	if isvalid(blessReset) and self.blessResetHandler ~= nil then
		blessReset:DisconnectEvent(ButtonClickEvent, self.blessResetHandler)
		self.blessResetHandler = nil
	end
	local blessAll = _EntityService:GetEntityByPath("/ui/BlessGroup/LeftRail/AllTab")
	if isvalid(blessAll) and self.blessAllHandler ~= nil then
		blessAll:DisconnectEvent(ButtonClickEvent, self.blessAllHandler)
		self.blessAllHandler = nil
	end
	local blessLock = _EntityService:GetEntityByPath("/ui/BlessGroup/LeftRail/LockTab")
	if isvalid(blessLock) and self.blessLockHandler ~= nil then
		blessLock:DisconnectEvent(ButtonClickEvent, self.blessLockHandler)
		self.blessLockHandler = nil
	end
	local blessUpgrade = _EntityService:GetEntityByPath("/ui/BlessGroup/DetailPanel/Detail/UpgradeBtn")
	if isvalid(blessUpgrade) and self.blessUpgradeHandler ~= nil then
		blessUpgrade:DisconnectEvent(ButtonClickEvent, self.blessUpgradeHandler)
		self.blessUpgradeHandler = nil
	end
	local blessClose = _EntityService:GetEntityByPath("/ui/BlessGroup/DetailPanel/Detail/CloseBtn")
	if isvalid(blessClose) and self.blessCloseHandler ~= nil then
		blessClose:DisconnectEvent(ButtonClickEvent, self.blessCloseHandler)
		self.blessCloseHandler = nil
	end
	local settingsBtn = _EntityService:GetEntityByPath("/ui/LobbyGroup/SettingsBtn")
	if isvalid(settingsBtn) and self.settingsHandler ~= nil then
		settingsBtn:DisconnectEvent(ButtonClickEvent, self.settingsHandler)
		self.settingsHandler = nil
	end
	local settingsClose = _EntityService:GetEntityByPath("/ui/SettingsGroup/CloseBtn")
	if isvalid(settingsClose) and self.settingsCloseHandler ~= nil then
		settingsClose:DisconnectEvent(ButtonClickEvent, self.settingsCloseHandler)
		self.settingsCloseHandler = nil
	end
	local bgmSlider = _EntityService:GetEntityByPath("/ui/SettingsGroup/Panel/BgmSlider")
	if isvalid(bgmSlider) and self.bgmSliderHandler ~= nil then
		bgmSlider:DisconnectEvent(SliderValueChangedEvent, self.bgmSliderHandler)
		self.bgmSliderHandler = nil
	end
	local sfxSlider = _EntityService:GetEntityByPath("/ui/SettingsGroup/Panel/SfxSlider")
	if isvalid(sfxSlider) and self.sfxSliderHandler ~= nil then
		sfxSlider:DisconnectEvent(SliderValueChangedEvent, self.sfxSliderHandler)
		self.sfxSliderHandler = nil
	end
	local shopBack = _EntityService:GetEntityByPath("/ui/ShopGroup/BackBtn")
	if isvalid(shopBack) and self.shopBackHandler ~= nil then
		shopBack:DisconnectEvent(ButtonClickEvent, self.shopBackHandler)
		self.shopBackHandler = nil
	end
	if self.shopCells ~= nil then
		for _, cell in ipairs(self.shopCells) do
			if isvalid(cell.buy) and cell.hd ~= nil then
				cell.buy:DisconnectEvent(ButtonClickEvent, cell.hd)
			end
		end
		self.shopCells = nil
	end
	self:ClearGaugeTimers()
end

end
