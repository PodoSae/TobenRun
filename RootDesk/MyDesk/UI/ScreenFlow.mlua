@Logic
script ScreenFlow extends Logic

property Entity titleRoot = "e6d3da67-eb3c-4afd-9abe-cf06ec90ed0e"
property Entity lobbyRoot = "6d97a194-546c-4732-b0c9-b0f843872f61"
-- Stage-select screen root (map selection lives here now; toggled like the shop).
property Entity stageSelectRoot = "8c910774-9791-4dd1-8c70-f55550f68b93"
property Entity startButton = "4cc83fed-af0a-48bc-a88a-2a3fa9747f9c"
property Entity backButton = "1d6433fa-a4ea-41f6-a01b-fb36b2daf066"
property Entity startGameButton = "86b0e64c-95b4-411a-94de-64f02121927d"
-- Title "터치하여 시작" prompt text — its alpha pulses while the title screen is visible.
property Entity titleHint = "a42897a4-904a-428e-ad8d-ba0bac85cdb8"
property number hintPulseT = 0
property any startHandler = nil
property any backHandler = nil
property any startGameHandler = nil
property any stageHandlers = nil
property any stageSelectOpenHandler = nil
property any stageSelectBackHandler = nil
property any equipHandler = nil
property any equipBackHandler = nil
property any blessHandler = nil
property any blessBackHandler = nil
property any blessUpHandler = nil
property any blessRowHandlers = nil
property any blessResetHandler = nil
property any blessAllHandler = nil
property any blessLockHandler = nil
property any blessUpgradeHandler = nil
property any blessCloseHandler = nil
-- Currently selected 축복 효과 id ("" = none → right detail panel content hidden).
property string blessSelected = ""
property any settingsHandler = nil
property any settingsCloseHandler = nil
property any bgmSliderHandler = nil
property any sfxSliderHandler = nil
property any shopBackHandler = nil
property any shopCells = nil
-- Running gauge fill-animation timer ids (cleared on rebuild / end play).
property any gaugeTimers = nil
-- 축복 button icon idle animation (3 layers): aura (static, glow pulse) + wings (flap) + sword (float).
property any blessWings = nil
property any blessRing = nil
property any blessAura = nil
property number blessT = 0
property number ringBaseX = 0
property number ringBaseY = 0
property number wgBaseSX = 1
property number wgBaseSY = 1
property boolean blessInit = false
-- 장비 button icon idle animation: gentle vertical float (bob up/down).
property any equipIcon = nil
property number eqBaseX = 0
property number eqBaseY = 0

@ExecSpace("ClientOnly")
method void OnBeginPlay()
	-- Show the title screen first, hide the lobby, and wire the buttons.
	if isvalid(self.titleRoot) then
		self.titleRoot.Enable = true
	end
	if isvalid(self.lobbyRoot) then
		self.lobbyRoot.Enable = false
	end
	-- Stage-select screen starts hidden (opened from the lobby).
	if isvalid(self.stageSelectRoot) then
		self.stageSelectRoot.Enable = false
	end
	if isvalid(self.startButton) then
		self.startHandler = self.startButton:ConnectEvent(ButtonClickEvent, self.OnStartClick)
	end
	if isvalid(self.backButton) then
		self.backHandler = self.backButton:ConnectEvent(ButtonClickEvent, self.OnBackClick)
	end
	if isvalid(self.startGameButton) then
		self.startGameHandler = self.startGameButton:ConnectEvent(ButtonClickEvent, self.OnStartGameClick)
	end
	-- Wire the stage buttons in the StageSelect screen (see StageList — currently 1-1 / 1-2 / 1-3).
	self.stageHandlers = {}
	for _, stage in ipairs(self:StageList()) do
		local path = "/ui/StageSelectGroup/Stage_" .. string.gsub(stage, "-", "_")
		local btn = _EntityService:GetEntityByPath(path)
		if isvalid(btn) then
			local capturedStage = stage
			local h = btn:ConnectEvent(ButtonClickEvent, function() self:OnStageClick(capturedStage) end)
			table.insert(self.stageHandlers, { ent = btn, hd = h })
		end
	end
	-- "모험 시작!" button opens the StageSelect screen (game start -> pick a stage).
	local startBtn = _EntityService:GetEntityByPath("/ui/LobbyGroup/StartBtn")
	if isvalid(startBtn) then
		self.stageSelectOpenHandler = startBtn:ConnectEvent(ButtonClickEvent, self.OnStageSelectOpenClick)
	end
	local stageBack = _EntityService:GetEntityByPath("/ui/StageSelectGroup/BackBtn")
	if isvalid(stageBack) then
		self.stageSelectBackHandler = stageBack:ConnectEvent(ButtonClickEvent, self.OnStageSelectBackClick)
	end
	-- Shop screen kept hidden (no longer opened from the lobby; the shop button became 장비).
	local shop = _EntityService:GetEntityByPath("/ui/ShopGroup")
	if isvalid(shop) then
		shop.Enable = false
	end
	local shopBack = _EntityService:GetEntityByPath("/ui/ShopGroup/BackBtn")
	if isvalid(shopBack) then
		self.shopBackHandler = shopBack:ConnectEvent(ButtonClickEvent, self.OnShopBackClick)
	end
	-- Equipment screen (temporary empty screen): hidden at start; wire its back button.
	local equip = _EntityService:GetEntityByPath("/ui/EquipGroup")
	if isvalid(equip) then
		equip.Enable = false
	end
	local equipBack = _EntityService:GetEntityByPath("/ui/EquipGroup/BackBtn")
	if isvalid(equipBack) then
		self.equipBackHandler = equipBack:ConnectEvent(ButtonClickEvent, self.OnEquipBackClick)
	end
	-- Blessing screen (temporary empty screen): hidden at start; wire its back button.
	local bless = _EntityService:GetEntityByPath("/ui/BlessGroup")
	if isvalid(bless) then
		bless.Enable = false
	end
	local blessBack = _EntityService:GetEntityByPath("/ui/BlessGroup/BackBtn")
	if isvalid(blessBack) then
		self.blessBackHandler = blessBack:ConnectEvent(ButtonClickEvent, self.OnBlessBackClick)
	end
	-- Lobby menu buttons: 장비 / 모험가의 축복 open their screens; 설정 is a placeholder.
	local equipBtn = _EntityService:GetEntityByPath("/ui/LobbyGroup/EquipBtn")
	if isvalid(equipBtn) then
		self.equipHandler = equipBtn:ConnectEvent(ButtonClickEvent, self.OnEquipClick)
	end
	local blessBtn = _EntityService:GetEntityByPath("/ui/LobbyGroup/BlessBtn")
	if isvalid(blessBtn) then
		self.blessHandler = blessBtn:ConnectEvent(ButtonClickEvent, self.OnBlessClick)
	end
	-- 축복 레벨업 button (inside the blessing page).
	local blessUp = _EntityService:GetEntityByPath("/ui/BlessGroup/EffectList/LevelUpBtn")
	if isvalid(blessUp) then
		self.blessUpHandler = blessUp:ConnectEvent(ButtonClickEvent, self.OnBlessLevelUpClick)
	end
	-- 축복 효과 행(Row_<id>) — 클릭 시 그 효과를 선택하고 우측 상세(강화) 패널을 연다. closure captures the id.
	self.blessRowHandlers = {}
	local beds = _DataService:GetTable("BlessEffect")
	if beds ~= nil then
		for i = 1, beds:GetRowCount() do
			local row = beds:GetRow(i)
			if row ~= nil then
				local eid = row:GetItem("id")
				if eid ~= nil and eid ~= "" then
					local rowBtn = _EntityService:GetEntityByPath("/ui/BlessGroup/EffectList/Row_" .. eid)
					if isvalid(rowBtn) then
						local capturedId = eid
						local rh = rowBtn:ConnectEvent(ButtonClickEvent, function() self:OnBlessRowClick(capturedId) end)
						table.insert(self.blessRowHandlers, { ent = rowBtn, hd = rh })
					end
				end
			end
		end
	end
	-- 축복 효과 초기화 button (inside the blessing page) — resets all effect levels to 0 (level kept).
	local blessReset = _EntityService:GetEntityByPath("/ui/BlessGroup/EffectList/ResetBtn")
	if isvalid(blessReset) then
		self.blessResetHandler = blessReset:ConnectEvent(ButtonClickEvent, self.OnBlessResetClick)
	end
	-- 좌측 카테고리 탭 (ALL만 동작, 잠금은 자리표시자) + 우측 상세 패널의 강화/닫기 버튼.
	local allTab = _EntityService:GetEntityByPath("/ui/BlessGroup/LeftRail/AllTab")
	if isvalid(allTab) then
		self.blessAllHandler = allTab:ConnectEvent(ButtonClickEvent, self.OnBlessAllTabClick)
	end
	local lockTab = _EntityService:GetEntityByPath("/ui/BlessGroup/LeftRail/LockTab")
	if isvalid(lockTab) then
		self.blessLockHandler = lockTab:ConnectEvent(ButtonClickEvent, self.OnBlessLockTabClick)
	end
	local upgradeBtn = _EntityService:GetEntityByPath("/ui/BlessGroup/DetailPanel/Detail/UpgradeBtn")
	if isvalid(upgradeBtn) then
		self.blessUpgradeHandler = upgradeBtn:ConnectEvent(ButtonClickEvent, self.OnBlessUpgradeClick)
	end
	local closeBtn = _EntityService:GetEntityByPath("/ui/BlessGroup/DetailPanel/Detail/CloseBtn")
	if isvalid(closeBtn) then
		self.blessCloseHandler = closeBtn:ConnectEvent(ButtonClickEvent, self.OnBlessDetailClose)
	end
	-- Cache the 축복 icon's 3 animation layers (aura / wings / ring) for the idle animation.
	self.blessAura = _EntityService:GetEntityByPath("/ui/LobbyGroup/BlessBtn/Icon")
	self.blessWings = _EntityService:GetEntityByPath("/ui/LobbyGroup/BlessBtn/Icon/Wings")
	self.blessRing = _EntityService:GetEntityByPath("/ui/LobbyGroup/BlessBtn/Icon/ring")
	-- Cache the 장비 button icon (child of the button's Aura) for its idle vertical float.
	self.equipIcon = _EntityService:GetEntityByPath("/ui/LobbyGroup/EquipBtn/Aura/Icon")
	local settingsBtn = _EntityService:GetEntityByPath("/ui/LobbyGroup/SettingsBtn")
	if isvalid(settingsBtn) then
		self.settingsHandler = settingsBtn:ConnectEvent(ButtonClickEvent, self.OnSettingsClick)
	end
	-- Settings popup: overlay hidden at start; wire close button + the two volume sliders.
	local settings = _EntityService:GetEntityByPath("/ui/SettingsGroup")
	if isvalid(settings) then
		settings.Enable = false
	end
	local settingsClose = _EntityService:GetEntityByPath("/ui/SettingsGroup/CloseBtn")
	if isvalid(settingsClose) then
		self.settingsCloseHandler = settingsClose:ConnectEvent(ButtonClickEvent, self.OnSettingsCloseClick)
	end
	local bgmSlider = _EntityService:GetEntityByPath("/ui/SettingsGroup/Panel/BgmSlider")
	if isvalid(bgmSlider) then
		self.bgmSliderHandler = bgmSlider:ConnectEvent(SliderValueChangedEvent, self.OnBgmVolumeChanged)
	end
	local sfxSlider = _EntityService:GetEntityByPath("/ui/SettingsGroup/Panel/SfxSlider")
	if isvalid(sfxSlider) then
		self.sfxSliderHandler = sfxSlider:ConnectEvent(SliderValueChangedEvent, self.OnSfxVolumeChanged)
	end
	-- Build the dynamic shop list (one cloned card per ShopItem dataset row).
	self:BuildShopList()
	-- Ask the server for this account's saved data (gold / best scores / item levels) → RefreshSavedUI.
	if _PlayerSave ~= nil then
		_PlayerSave:RequestMyData()
	end
	log("[ScreenFlow] OnBeginPlay: title shown")
end

@ExecSpace("ClientOnly")
method void OnUpdate(number delta)
	-- 축복 icon idle animation (runs regardless of the title-hint early-return below).
	self:AnimateBlessIcon(delta)
	-- Pulse the title "터치하여 시작" prompt's alpha up and down while the title screen is visible.
	if isvalid(self.titleHint) == false or self.titleHint.TextComponent == nil then
		return
	end
	local tc = self.titleHint.TextComponent
	local c = tc.FontColor
	if isvalid(self.titleRoot) and self.titleRoot.Enable then
		self.hintPulseT = self.hintPulseT + delta
		-- Sine breathing between alpha 0.25 and 1.0 (period ~1.6s).
		local a = 0.625 + 0.375 * math.sin(self.hintPulseT * 4.0)
		tc.FontColor = Color(c.r, c.g, c.b, a)
	elseif c.a ~= 1 then
		-- Title hidden → restore full opacity and reset the phase.
		tc.FontColor = Color(c.r, c.g, c.b, 1)
		self.hintPulseT = 0
	end
end

@ExecSpace("ClientOnly")
method void AnimateBlessIcon(number delta)
	-- Idle 축복 emblem animation (3 independent layers), only while the lobby is visible:
	--   wings  → quick horizontal-scale flap (with a small vertical counter-beat)
	--   ring   → slow vertical float (bob up/down)
	--   aura   → gentle glow pulse via alpha
	-- Base transforms are captured once on the first tick.
	if isvalid(self.lobbyRoot) == false or self.lobbyRoot.Enable == false then
		return
	end
	self.blessT = self.blessT + delta
	if self.blessInit == false then
		if isvalid(self.blessWings) and self.blessWings.UITransformComponent ~= nil then
			local sc = self.blessWings.UITransformComponent.UIScale
			self.wgBaseSX = sc.x
			self.wgBaseSY = sc.y
		end
		if isvalid(self.blessRing) and self.blessRing.UITransformComponent ~= nil then
			local ap = self.blessRing.UITransformComponent.anchoredPosition
			self.ringBaseX = ap.x
			self.ringBaseY = ap.y
		end
		if isvalid(self.equipIcon) and self.equipIcon.UITransformComponent ~= nil then
			local ep = self.equipIcon.UITransformComponent.anchoredPosition
			self.eqBaseX = ep.x
			self.eqBaseY = ep.y
		end
		self.blessInit = true
	end
	if isvalid(self.blessWings) and self.blessWings.UITransformComponent ~= nil then
		local flap = math.sin(self.blessT * 6.5)
		-- Original flap: X-scale grows/shrinks while Y counter-beats (wings beat).
		self.blessWings.UITransformComponent.UIScale = Vector3(self.wgBaseSX * (1.0 + 0.12 * flap), self.wgBaseSY * (1.0 - 0.06 * flap), 1)
	end
	if isvalid(self.blessRing) and self.blessRing.UITransformComponent ~= nil then
		local bob = 6.0 * math.sin(self.blessT * 2.4)
		self.blessRing.UITransformComponent.anchoredPosition = Vector2(self.ringBaseX, self.ringBaseY + bob)
	end
	-- 장비 icon → slow vertical float (bob up/down), slightly offset in phase from the 축복 ring.
	if isvalid(self.equipIcon) and self.equipIcon.UITransformComponent ~= nil then
		local eqBob = 7.0 * math.sin(self.blessT * 2.2 + 1.0)
		self.equipIcon.UITransformComponent.anchoredPosition = Vector2(self.eqBaseX, self.eqBaseY + eqBob)
	end
	if isvalid(self.blessAura) and self.blessAura.SpriteGUIRendererComponent ~= nil then
		local c = self.blessAura.SpriteGUIRendererComponent.Color
		local a = 0.78 + 0.22 * math.sin(self.blessT * 2.0)
		self.blessAura.SpriteGUIRendererComponent.Color = Color(c.r, c.g, c.b, a)
	end
end

@ExecSpace("ClientOnly")
method void RefreshSavedUI()
	-- Apply the cached account data to the lobby (stage best scores) and shop (owned marks).
	if _PlayerSave == nil then
		return
	end
	-- Gold balance on lobby + shop.
	local gold = _PlayerSave:GetGold()
	local goldText = "골드 " .. tostring(gold)
	local lobbyMeso = _EntityService:GetEntityByPath("/ui/LobbyGroup/CurrencyBar/MesoPill/Text")
	if isvalid(lobbyMeso) and lobbyMeso.TextComponent ~= nil then
		-- Number only (the pill icon already indicates 메소); abbreviated so big values fit the box.
		lobbyMeso.TextComponent.Text = self:AbbreviateNumber(gold)
	end
	-- 토벤코인 (used by equipment evolution) on lobby + equip screens.
	local coin = 0
	if _PlayerSave ~= nil then
		coin = _PlayerSave:GetCoin()
	end
	local lobbyCoin = _EntityService:GetEntityByPath("/ui/LobbyGroup/CurrencyBar/CoinPill/Text")
	if isvalid(lobbyCoin) and lobbyCoin.TextComponent ~= nil then
		-- Number only (the pill icon already indicates 토벤코인); abbreviated so big values fit the box.
		lobbyCoin.TextComponent.Text = self:AbbreviateNumber(coin)
	end
	local eqMeso = _EntityService:GetEntityByPath("/ui/EquipGroup/CurrencyBar/MesoPill/Text")
	if isvalid(eqMeso) and eqMeso.TextComponent ~= nil then
		eqMeso.TextComponent.Text = self:AbbreviateNumber(gold)
	end
	local eqCoin = _EntityService:GetEntityByPath("/ui/EquipGroup/CurrencyBar/CoinPill/Text")
	if isvalid(eqCoin) and eqCoin.TextComponent ~= nil then
		eqCoin.TextComponent.Text = self:AbbreviateNumber(coin)
	end
	-- If the equipment screen is open, re-sync it after any save change (enhance/evolve/currency).
	local eqGroup = _EntityService:GetEntityByPath("/ui/EquipGroup")
	if isvalid(eqGroup) and eqGroup.Enable and _EquipScreen ~= nil then
		_EquipScreen:RefreshFromSave()
	end
	-- If the blessing screen is open, re-sync its currency + level/cost after any save change.
	local blGroup = _EntityService:GetEntityByPath("/ui/BlessGroup")
	if isvalid(blGroup) and blGroup.Enable then
		local blMeso = _EntityService:GetEntityByPath("/ui/BlessGroup/CurrencyBar/MesoPill/Text")
		if isvalid(blMeso) and blMeso.TextComponent ~= nil then
			blMeso.TextComponent.Text = self:AbbreviateNumber(gold)
		end
		local blCoin = _EntityService:GetEntityByPath("/ui/BlessGroup/CurrencyBar/CoinPill/Text")
		if isvalid(blCoin) and blCoin.TextComponent ~= nil then
			blCoin.TextComponent.Text = self:AbbreviateNumber(coin)
		end
		self:RefreshBlessUI()
	end
	-- Profile name → the local player's account nickname.
	local lp = _UserService.LocalPlayer
	if isvalid(lp) and lp.PlayerComponent ~= nil then
		local nick = lp.PlayerComponent.Nickname
		local nameEnt = _EntityService:GetEntityByPath("/ui/LobbyGroup/ProfileCard/Name")
		if isvalid(nameEnt) and nameEnt.TextComponent ~= nil and nick ~= nil and nick ~= "" then
			nameEnt.TextComponent.Text = nick
		end
		-- Profile image → the local player's own avatar (clone the user's equipped costume).
		local uid = lp.PlayerComponent.UserId
		local portrait = _EntityService:GetEntityByPath("/ui/LobbyGroup/ProfileCard/Portrait/Avatar")
		if isvalid(portrait) and portrait.CostumeManagerComponent ~= nil and uid ~= nil and uid ~= "" then
			if portrait.CostumeManagerComponent.DefaultEquipUserId ~= uid then
				portrait.CostumeManagerComponent.DefaultEquipUserId = uid
				-- The avatar is built a moment later; freeze it in a stand pose then (stops the default fly/idle bob).
				_TimerService:SetTimer(self, self.ApplyProfilePose, 0.5, false)
			end
		end
		-- Lobby center avatar → account base costume + the equipped 4-slot setup (mirrors the equip screen).
		local centerAv = _EntityService:GetEntityByPath("/ui/LobbyGroup/CharacterDisplay/Avatar")
		if isvalid(centerAv) and centerAv.CostumeManagerComponent ~= nil and uid ~= nil and uid ~= "" then
			if centerAv.CostumeManagerComponent.DefaultEquipUserId ~= uid then
				centerAv.CostumeManagerComponent.DefaultEquipUserId = uid
			end
			if _EquipScreen ~= nil then
				_EquipScreen:ApplyAppearanceTo("/ui/LobbyGroup/CharacterDisplay/Avatar")
			end
			-- Re-apply the equipped overrides + stand pose on a short delay so the DefaultEquipUserId
			-- account clone (async) doesn't overwrite the equipped slots or leave the default fly bob.
			_TimerService:SetTimer(self, self.RefreshLobbyAvatar, 0.6, false)
		end
	end
	local shopGold = _EntityService:GetEntityByPath("/ui/ShopGroup/Gold")
	if isvalid(shopGold) and shopGold.TextComponent ~= nil then
		shopGold.TextComponent.Text = goldText
	end
	local stageGold = _EntityService:GetEntityByPath("/ui/StageSelectGroup/Gold")
	if isvalid(stageGold) and stageGold.TextComponent ~= nil then
		stageGold.TextComponent.Text = goldText
	end
	-- Stage unlock gating: 1-1 is always open; every later stage opens once the PREVIOUS
	-- stage has been cleared (goal reached). Locked stages show a Lock overlay whose label
	-- names the stage that must be cleared first.
	for _, stage in ipairs(self:StageList()) do
		local btnPath = "/ui/StageSelectGroup/Stage_" .. string.gsub(stage, "-", "_")
		local locked = (self:IsStageUnlocked(stage) == false)
		local lockEnt = _EntityService:GetEntityByPath(btnPath .. "/Lock")
		if isvalid(lockEnt) then
			lockEnt.Enable = locked
			local reqEnt = _EntityService:GetEntityByPath(btnPath .. "/Lock/Req")
			if isvalid(reqEnt) and reqEnt.TextComponent ~= nil then
				reqEnt.TextComponent.Text = self:PrevStage(stage) .. " 클리어 필요"
			end
		end
		local best = _PlayerSave:GetStageBest(stage)
		local lbl = _EntityService:GetEntityByPath(btnPath .. "/Best")
		if isvalid(lbl) and lbl.TextComponent ~= nil then
			if best > 0 then
				lbl.TextComponent.Text = "최고 " .. tostring(best)
			else
				lbl.TextComponent.Text = ""
			end
		end
	end
	-- Apply the saved sound volumes to the SoundManager (restores the user's setting on login).
	if _SoundManager ~= nil then
		_SoundManager:SetBgmVolume(_PlayerSave:GetBgmVolume())
		_SoundManager:SetSfxVolume(_PlayerSave:GetSfxVolume())
	end
	-- Refresh the dynamic shop list (levels / prices / buy state).
	self:RefreshShopCells()
	log("[ScreenFlow] RefreshSavedUI")
end

@ExecSpace("ClientOnly")
method void StandAvatarAt(string path)
	-- Freeze the avatar at `path` in a stand pose so it doesn't play the default fly/idle bob.
	local av = _EntityService:GetEntityByPath(path)
	if isvalid(av) == false or av.AvatarGUIRendererComponent == nil then
		return
	end
	local body = av.AvatarGUIRendererComponent:GetBodyEntity()
	if isvalid(body) == false then
		return
	end
	local ev = ActionStateChangedEvent()
	ev.CoreActionName = "stand1"
	ev.PartsActionName = "stand1"
	ev.PlayType = SpriteAnimClipPlayType.ZigzagLoop
	body:SendEvent(ev)
end

@ExecSpace("ClientOnly")
method void ApplyProfilePose()
	-- Lobby profile avatar → stand pose.
	self:StandAvatarAt("/ui/LobbyGroup/ProfileCard/Portrait/Avatar")
	log("[ScreenFlow] profile avatar -> stand1")
end

@ExecSpace("ClientOnly")
method void StandEquipAvatars()
	-- Equip screen's two avatars (head portrait + full-body) → stand pose.
	self:StandAvatarAt("/ui/EquipGroup/ProfileCard/Portrait/Avatar")
	self:StandAvatarAt("/ui/EquipGroup/CharPanel/CharAvatar")
end

@ExecSpace("ClientOnly")
method void RefreshLobbyAvatar()
	-- Re-apply the equipped costume + stand pose to the lobby center avatar (deferred so the async
	-- DefaultEquipUserId account clone doesn't overwrite the equipped-slot overrides / fly bob).
	local path = "/ui/LobbyGroup/CharacterDisplay/Avatar"
	if _EquipScreen ~= nil then
		_EquipScreen:ApplyAppearanceTo(path)
	end
	self:StandAvatarAt(path)
end

@ExecSpace("ClientOnly")
method void FillEquipScreen()
	-- Populate the equipment screen's reused profile / currency / character from live player data.
	local lp = _UserService.LocalPlayer
	local uid = ""
	local nick = ""
	if isvalid(lp) and lp.PlayerComponent ~= nil then
		uid = lp.PlayerComponent.UserId
		nick = lp.PlayerComponent.Nickname
	end
	local nameEnt = _EntityService:GetEntityByPath("/ui/EquipGroup/ProfileCard/Name")
	if isvalid(nameEnt) and nameEnt.TextComponent ~= nil and nick ~= nil and nick ~= "" then
		nameEnt.TextComponent.Text = nick
	end
	-- Both avatars mirror the local player's costume (equipping will override slots later).
	for _, p in ipairs({ "/ui/EquipGroup/ProfileCard/Portrait/Avatar", "/ui/EquipGroup/CharPanel/CharAvatar" }) do
		local e = _EntityService:GetEntityByPath(p)
		if isvalid(e) and e.CostumeManagerComponent ~= nil and uid ~= nil and uid ~= "" then
			if e.CostumeManagerComponent.DefaultEquipUserId ~= uid then
				e.CostumeManagerComponent.DefaultEquipUserId = uid
			end
		end
	end
	_TimerService:SetTimer(self, self.StandEquipAvatars, 0.5, false)
	-- Currency (meso from save; coin stays a placeholder).
	local gold = 0
	if _PlayerSave ~= nil then
		gold = _PlayerSave:GetGold()
	end
	local m = _EntityService:GetEntityByPath("/ui/EquipGroup/CurrencyBar/MesoPill/Text")
	if isvalid(m) and m.TextComponent ~= nil then
		m.TextComponent.Text = self:AbbreviateNumber(gold)
	end
	local coin = 0
	if _PlayerSave ~= nil then
		coin = _PlayerSave:GetCoin()
	end
	local cc = _EntityService:GetEntityByPath("/ui/EquipGroup/CurrencyBar/CoinPill/Text")
	if isvalid(cc) and cc.TextComponent ~= nil then
		cc.TextComponent.Text = self:AbbreviateNumber(coin)
	end
end

@ExecSpace("ClientOnly")
method void BuildShopList()
	-- Clone one card per ShopItem dataset row into the scroll list (clears any prior clones).
	self:ClearGaugeTimers()
	if self.shopCells ~= nil then
		for _, cell in ipairs(self.shopCells) do
			if isvalid(cell.buy) and cell.hd ~= nil then
				cell.buy:DisconnectEvent(ButtonClickEvent, cell.hd)
			end
			if isvalid(cell.clone) then
				cell.clone:Destroy()
			end
		end
	end
	self.shopCells = {}
	local template = _EntityService:GetEntityByPath("/ui/ShopGroup/List/ItemCard")
	if isvalid(template) == false then
		return
	end
	template.Enable = false
	local sds = _DataService:GetTable("ShopItem")
	if sds == nil then
		return
	end
	local n = sds:GetRowCount()
	for i = 1, n do
		local row = sds:GetRow(i)
		if row ~= nil then
			local id = row:GetItem("id")
			local clone = template:Clone("Item_" .. id)
			clone.Enable = true
			local iconEnt = clone:GetChildByName("Icon", false)
			if isvalid(iconEnt) and iconEnt.SpriteGUIRendererComponent ~= nil then
				local r = (tonumber(row:GetItem("r")) or 255) / 255
				local g = (tonumber(row:GetItem("g")) or 255) / 255
				local bl = (tonumber(row:GetItem("b")) or 255) / 255
				iconEnt.SpriteGUIRendererComponent.Color = Color(r, g, bl, 1)
			end
			local nameEnt = clone:GetChildByName("Name", false)
			if isvalid(nameEnt) and nameEnt.TextComponent ~= nil then
				nameEnt.TextComponent.Text = row:GetItem("name")
			end
			local infoEnt = clone:GetChildByName("Info", false)
			local buyEnt = clone:GetChildByName("Buy", false)
			-- Gather the 5 gauge cells + their rising-fill sprites, tinted with the item color.
			local fillColor = Color(
				(tonumber(row:GetItem("r")) or 255) / 255,
				(tonumber(row:GetItem("g")) or 255) / 255,
				(tonumber(row:GetItem("b")) or 255) / 255,
				1)
			local gaugeEnt = clone:GetChildByName("Gauge", false)
			local cellEnts = {}
			local fills = {}
			if isvalid(gaugeEnt) then
				for c = 1, 5 do
					local ce = gaugeEnt:GetChildByName("Cell" .. tostring(c), false)
					cellEnts[c] = ce
					if isvalid(ce) then
						local fe = ce:GetChildByName("Fill", false)
						if isvalid(fe) and fe.SpriteGUIRendererComponent ~= nil then
							fe.SpriteGUIRendererComponent.Color = fillColor
							fe.SpriteGUIRendererComponent.FillAmount = 0
							fills[c] = fe.SpriteGUIRendererComponent
						end
					end
				end
			end
			local badgeEnt = clone:GetChildByName("OwnedBadge", false)
			if isvalid(badgeEnt) then
				badgeEnt.Enable = false
			end
			local capturedId = id
			local hd = nil
			if isvalid(buyEnt) then
				hd = buyEnt:ConnectEvent(ButtonClickEvent, function() self:OnBuyClick(capturedId) end)
			end
			table.insert(self.shopCells, { id = id, clone = clone, info = infoEnt, buy = buyEnt, hd = hd, cellEnts = cellEnts, fills = fills, badge = badgeEnt, level = -1 })
		end
	end
	log("[ScreenFlow] BuildShopList count=" .. tostring(#self.shopCells))
end

@ExecSpace("ClientOnly")
method void RefreshShopCells()
	-- Update each cloned card's level / next-cost / buy-button state from save + dataset.
	if self.shopCells == nil or _PlayerSave == nil then
		return
	end
	local sds = _DataService:GetTable("ShopItem")
	if sds == nil then
		return
	end
	for _, cell in ipairs(self.shopCells) do
		local row = sds:FindRow("id", cell.id)
		local price = 0
		local priceInc = 0
		local maxLevel = 0
		if row ~= nil then
			price = tonumber(row:GetItem("price")) or 0
			priceInc = tonumber(row:GetItem("priceInc")) or 0
			maxLevel = tonumber(row:GetItem("maxLevel")) or 0
		end
		local level = _PlayerSave:GetItemLevel(cell.id)
		local atMax = level >= maxLevel
		local prev = cell.level
		-- Animate only when this is a real increase from a known prior state (not first load).
		local doAnim = (prev >= 0 and level > prev)
		-- Show only maxLevel cells; fill the owned ones (rising one-by-one on a fresh purchase).
		if cell.cellEnts ~= nil then
			for c = 1, 5 do
				local ce = cell.cellEnts[c]
				if isvalid(ce) then
					ce.Enable = (c <= maxLevel)
				end
				local fc = cell.fills[c]
				if fc ~= nil and isvalid(fc) then
					if c <= level then
						if doAnim and c > prev then
							-- newly gained cell → rise from empty with a small stagger
							self:AnimateCellRise(fc, (c - prev - 1) * 0.12, 0.3)
						else
							fc.FillAmount = 1
						end
					else
						fc.FillAmount = 0
					end
				end
			end
		end
		cell.level = level
		-- "보유" badge appears once the item has been purchased at least once.
		if isvalid(cell.badge) then
			cell.badge.Enable = (level >= 1)
		end
		-- Cost caption (the level number now lives in the gauge, so show price only).
		if isvalid(cell.info) and cell.info.TextComponent ~= nil then
			if atMax then
				cell.info.TextComponent.Text = "최대 강화 완료"
			else
				local cost = _PlayerSave:ShopItemCost(price, priceInc, level)
				cell.info.TextComponent.Text = "다음 " .. tostring(cost) .. " G"
			end
		end
		if isvalid(cell.buy) and cell.buy.TextComponent ~= nil then
			if atMax then
				cell.buy.TextComponent.Text = "최대"
				if cell.buy.SpriteGUIRendererComponent ~= nil then
					cell.buy.SpriteGUIRendererComponent.Color = Color(0.45, 0.45, 0.45, 1)
				end
			else
				cell.buy.TextComponent.Text = "구매"
				if cell.buy.SpriteGUIRendererComponent ~= nil then
					cell.buy.SpriteGUIRendererComponent.Color = Color(0.18, 0.62, 0.38, 1)
				end
			end
		end
	end
end

@ExecSpace("ClientOnly")
method void AnimateCellRise(SpriteGUIRendererComponent fill, number delay, number dur)
	-- Rising fill (0 → 1) for one gauge cell after an optional start delay.
	if fill == nil or isvalid(fill) == false then
		return
	end
	if self.gaugeTimers == nil then
		self.gaugeTimers = {}
	end
	fill.FillAmount = 0
	local elapsed = 0
	local preTime = _UtilLogic.ElapsedSeconds
	local timerId = nil
	timerId = _TimerService:SetTimerRepeat(function()
		local now = _UtilLogic.ElapsedSeconds
		elapsed = elapsed + (now - preTime)
		preTime = now
		if isvalid(fill) == false then
			_TimerService:ClearTimer(timerId)
			return
		end
		if elapsed < delay then
			return
		end
		local t = (elapsed - delay) / dur
		if t >= 1 then
			fill.FillAmount = 1
			_TimerService:ClearTimer(timerId)
			return
		end
		fill.FillAmount = t
	end, 1 / 60)
	table.insert(self.gaugeTimers, timerId)
end

@ExecSpace("ClientOnly")
method void ClearGaugeTimers()
	-- Stop any in-flight gauge fill animations.
	if self.gaugeTimers ~= nil then
		for _, tid in ipairs(self.gaugeTimers) do
			if tid ~= nil then
				_TimerService:ClearTimer(tid)
			end
		end
	end
	self.gaugeTimers = {}
end

