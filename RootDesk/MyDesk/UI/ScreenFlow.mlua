@ExecSpace("ClientOnly")
method void FillBlessScreen()
	-- Populate the 축복 screen's currency, clear any prior selection (right detail starts hidden),
	-- then refresh the level / points / effect list. (No profile avatar on this screen anymore.)
	local gold = 0
	local coin = 0
	if _PlayerSave ~= nil then
		gold = _PlayerSave:GetGold()
		coin = _PlayerSave:GetCoin()
	end
	local m = _EntityService:GetEntityByPath("/ui/BlessGroup/CurrencyBar/MesoPill/Text")
	if isvalid(m) and m.TextComponent ~= nil then
		m.TextComponent.Text = self:AbbreviateNumber(gold)
	end
	local c = _EntityService:GetEntityByPath("/ui/BlessGroup/CurrencyBar/CoinPill/Text")
	if isvalid(c) and c.TextComponent ~= nil then
		c.TextComponent.Text = self:AbbreviateNumber(coin)
	end
	self:ClearBlessSelection()
	self:RefreshBlessUI()
end

method string BlessEffectDesc(string effectId)
	-- Static Korean flavor text per effect (the BlessEffect DataSet has no description column).
	if effectId == "pierce" then
		return "투사체가 적을 더 많이 관통합니다."
	elseif effectId == "crit" then
		return "일반 몬스터를 확률로 즉사시킵니다."
	elseif effectId == "hitcount" then
		return "확률로 추가 타격이 1회 발생합니다."
	elseif effectId == "swift" then
		return "공격 속도가 빨라집니다."
	elseif effectId == "regen" then
		return "10초마다 최대 체력의 일부를 회복합니다."
	elseif effectId == "iframe" then
		return "피격 시 무적 시간이 늘어납니다."
	end
	return ""
end

method string BlessEffectUnit(string effectId)
	-- Value suffix shown in the detail panel per effect.
	if effectId == "pierce" then
		return "회 관통"
	elseif effectId == "crit" then
		return "% 즉사"
	elseif effectId == "hitcount" then
		return "% 확률"
	elseif effectId == "swift" then
		return "%"
	elseif effectId == "regen" then
		return "% 회복"
	elseif effectId == "iframe" then
		return "초"
	end
	return ""
end

method any BlessEffectColor(string effectId)
	-- Icon color per effect (mirrors the swatches placed in BlessGroup.ui).
	if effectId == "pierce" then
		return Color(0.90, 0.30, 0.30, 1)
	elseif effectId == "crit" then
		return Color(0.96, 0.62, 0.22, 1)
	elseif effectId == "hitcount" then
		return Color(0.34, 0.60, 0.95, 1)
	elseif effectId == "swift" then
		return Color(0.34, 0.75, 0.45, 1)
	elseif effectId == "regen" then
		return Color(0.92, 0.50, 0.66, 1)
	elseif effectId == "iframe" then
		return Color(0.60, 0.45, 0.85, 1)
	end
	return Color(0.9, 0.3, 0.3, 1)
end

@ExecSpace("ClientOnly")
method void RefreshBlessUI()
	-- Update the 축복 page from save: level header, level-up cost, top point pill, and each effect row
	-- (name / description / level pill / selection highlight). Refreshes the detail panel if one is open.
	if _PlayerSave == nil then
		return
	end
	local level = _PlayerSave:GetBlessLevel()
	local lvEnt = _EntityService:GetEntityByPath("/ui/BlessGroup/EffectList/LevelText")
	if isvalid(lvEnt) and lvEnt.TextComponent ~= nil then
		lvEnt.TextComponent.Text = "축복 레벨 " .. tostring(level)
	end
	-- Level-up row (replaces the excluded XP bar): show the next 토벤코인 cost.
	local upEnt = _EntityService:GetEntityByPath("/ui/BlessGroup/EffectList/LevelUpBtn")
	if isvalid(upEnt) and upEnt.TextComponent ~= nil then
		upEnt.TextComponent.Text = "레벨업   ·   다음 레벨 " .. tostring(_PlayerSave:BlessLevelUpCost(level)) .. " 토벤코인"
	end
	-- Free 축복 포인트 → top "P" pill.
	local free = _PlayerSave:GetBlessFreePoints()
	local ptEnt = _EntityService:GetEntityByPath("/ui/BlessGroup/CurrencyBar/PointPill/Text")
	if isvalid(ptEnt) and ptEnt.TextComponent ~= nil then
		ptEnt.TextComponent.Text = tostring(free)
	end
	-- Effect rows.
	local eds = _DataService:GetTable("BlessEffect")
	if eds ~= nil then
		for i = 1, eds:GetRowCount() do
			local row = eds:GetRow(i)
			if row ~= nil then
				local id = row:GetItem("id")
				if id ~= nil and id ~= "" then
					local elv = _PlayerSave:GetEffectLevel(id)
					local nameEnt = _EntityService:GetEntityByPath("/ui/BlessGroup/EffectList/Row_" .. id .. "/Name")
					if isvalid(nameEnt) and nameEnt.TextComponent ~= nil then
						nameEnt.TextComponent.Text = tostring(row:GetItem("name"))
					end
					local descEnt = _EntityService:GetEntityByPath("/ui/BlessGroup/EffectList/Row_" .. id .. "/Desc")
					if isvalid(descEnt) and descEnt.TextComponent ~= nil then
						descEnt.TextComponent.Text = self:BlessEffectDesc(id)
					end
					local lvTxt = _EntityService:GetEntityByPath("/ui/BlessGroup/EffectList/Row_" .. id .. "/LvPill/Txt")
					if isvalid(lvTxt) and lvTxt.TextComponent ~= nil then
						lvTxt.TextComponent.Text = "Lv." .. tostring(elv)
					end
					-- Selection highlight (selected row bright, others tan).
					local rowEnt = _EntityService:GetEntityByPath("/ui/BlessGroup/EffectList/Row_" .. id)
					if isvalid(rowEnt) and rowEnt.SpriteGUIRendererComponent ~= nil then
						if id == self.blessSelected then
							rowEnt.SpriteGUIRendererComponent.Color = Color(0.99, 0.93, 0.72, 1)
						else
							rowEnt.SpriteGUIRendererComponent.Color = Color(0.86, 0.79, 0.64, 1)
						end
					end
				end
			end
		end
	end
	if self.blessSelected ~= nil and self.blessSelected ~= "" then
		self:RefreshBlessDetail()
	end
end

@ExecSpace("ClientOnly")
method void RefreshBlessDetail()
	-- Fill the right detail panel for the currently selected effect (name / icon / level / value / cost).
	if _PlayerSave == nil or self.blessSelected == nil or self.blessSelected == "" then
		return
	end
	local eds = _DataService:GetTable("BlessEffect")
	if eds == nil then
		return
	end
	local row = eds:FindRow("id", self.blessSelected)
	if row == nil then
		return
	end
	local id = self.blessSelected
	local maxLv = tonumber(row:GetItem("maxLevel")) or 5
	local elv = _PlayerSave:GetEffectLevel(id)
	local unit = self:BlessEffectUnit(id)
	local nameEnt = _EntityService:GetEntityByPath("/ui/BlessGroup/DetailPanel/Detail/DetName")
	if isvalid(nameEnt) and nameEnt.TextComponent ~= nil then
		nameEnt.TextComponent.Text = tostring(row:GetItem("name"))
	end
	local descEnt = _EntityService:GetEntityByPath("/ui/BlessGroup/DetailPanel/Detail/DetDesc")
	if isvalid(descEnt) and descEnt.TextComponent ~= nil then
		descEnt.TextComponent.Text = self:BlessEffectDesc(id)
	end
	local iconEnt = _EntityService:GetEntityByPath("/ui/BlessGroup/DetailPanel/Detail/DetIcon")
	if isvalid(iconEnt) and iconEnt.SpriteGUIRendererComponent ~= nil then
		iconEnt.SpriteGUIRendererComponent.Color = self:BlessEffectColor(id)
	end
	local lvEnt = _EntityService:GetEntityByPath("/ui/BlessGroup/DetailPanel/Detail/DetLv")
	if isvalid(lvEnt) and lvEnt.TextComponent ~= nil then
		if elv >= maxLv then
			lvEnt.TextComponent.Text = "Lv." .. tostring(elv) .. " (최대)"
		else
			lvEnt.TextComponent.Text = "Lv." .. tostring(elv) .. " › Lv." .. tostring(elv + 1)
		end
	end
	local valEnt = _EntityService:GetEntityByPath("/ui/BlessGroup/DetailPanel/Detail/DetValue")
	if isvalid(valEnt) and valEnt.TextComponent ~= nil then
		local curVal = "0"
		if elv >= 1 then
			curVal = tostring(row:GetItem("lv" .. tostring(elv)))
		end
		if elv >= maxLv then
			valEnt.TextComponent.Text = "효과량 : " .. curVal .. unit .. " (최대)"
		else
			local nextVal = tostring(row:GetItem("lv" .. tostring(elv + 1)))
			valEnt.TextComponent.Text = "효과량 : " .. curVal .. unit .. " › " .. nextVal .. unit
		end
	end
	local upBtn = _EntityService:GetEntityByPath("/ui/BlessGroup/DetailPanel/Detail/UpgradeBtn")
	if isvalid(upBtn) and upBtn.TextComponent ~= nil then
		if elv >= maxLv then
			upBtn.TextComponent.Text = "최대 레벨"
			if upBtn.SpriteGUIRendererComponent ~= nil then
				upBtn.SpriteGUIRendererComponent.Color = Color(0.55, 0.55, 0.55, 1)
			end
		else
			local cost = _PlayerSave:EffectUpgradeCost(elv)
			upBtn.TextComponent.Text = "강화 (" .. tostring(cost) .. " P)"
			if upBtn.SpriteGUIRendererComponent ~= nil then
				if _PlayerSave:GetBlessFreePoints() >= cost then
					upBtn.SpriteGUIRendererComponent.Color = Color(0.96, 0.79, 0.24, 1)
				else
					upBtn.SpriteGUIRendererComponent.Color = Color(0.55, 0.47, 0.3, 1)
				end
			end
		end
	end
end

@ExecSpace("ClientOnly")
method void ClearBlessSelection()
	-- Deselect: hide the right detail content (back-board stays), show the "select an effect" hint.
	self.blessSelected = ""
	local detail = _EntityService:GetEntityByPath("/ui/BlessGroup/DetailPanel/Detail")
	if isvalid(detail) then
		detail.Enable = false
	end
	local hint = _EntityService:GetEntityByPath("/ui/BlessGroup/DetailPanel/EmptyHint")
	if isvalid(hint) then
		hint.Enable = true
	end
end

